# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# SQLite transient files (WAL + shared-memory). The main DB ships in the
# repo so anyone cloning gets the sample seed data without re-running scripts.
/data/*.db-wal
/data/*.db-shm
/backups

# user-uploaded media (samples in /public/samples are committed)
/public/avatars
/public/post-images

# pm2 logs
/logs

# editor/OS
.idea
.vscode
Thumbs.db

